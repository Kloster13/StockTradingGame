<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="670.0" prefWidth="865.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="presentation.controllers.HomeViewController">
    <children>
        <HBox alignment="CENTER" prefHeight="670.0" prefWidth="865.0">
            <children>
                <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="681.0" prefWidth="400.0">
                    <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Welcome to the stock trading game!" textAlignment="CENTER" />
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Chose or create a portfolio, then start the game" textAlignment="CENTER">
                            <VBox.margin>
                                <Insets bottom="20.0" />
                            </VBox.margin>
                        </Text>
                        <ComboBox fx:id="portfolioCombo" prefHeight="25.0" prefWidth="232.0" promptText="Select portfolio">
                            <VBox.margin>
                                <Insets bottom="20.0" />
                            </VBox.margin>
                        </ComboBox>
                  <GridPane>
                    <columnConstraints>
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                     <children>
                        <Label text="Select fee calculation" GridPane.halignment="RIGHT">
                           <GridPane.margin>
                              <Insets right="10.0" />
                           </GridPane.margin>
                        </Label>
                        <ComboBox fx:id="feeStrategyCombo" onAction="#handleFeeStrategy" prefWidth="150.0" GridPane.columnIndex="1">
                           <GridPane.margin>
                              <Insets left="10.0" />
                           </GridPane.margin>
                        </ComboBox>
                     </children>
                  </GridPane>
                        <HBox alignment="CENTER" prefHeight="48.0" prefWidth="256.0" spacing="20.0">
                            <children>
                                <Button fx:id="startGameButton" mnemonicParsing="false" onAction="#handleStartGame" text="Start Game" />
                        <Button fx:id="stopGameButton" mnemonicParsing="false" onAction="#handleStop" text="Stop game" />
                            </children>
                        </HBox>
                  <HBox alignment="CENTER" prefHeight="48.0" prefWidth="256.0" spacing="20.0">
                     <children>
                                <Button fx:id="resetGameButton" mnemonicParsing="false" onAction="#handleReset" text="Reset Game" />
                     </children>
                  </HBox>
                    </children>
                    <opaqueInsets>
                        <Insets />
                    </opaqueInsets>
                    <padding>
                        <Insets top="40.0" />
                    </padding>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
