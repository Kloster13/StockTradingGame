                        <CategoryAxis side="BOTTOM"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT"/>
                    </yAxis>
                    <padding>
                        <Insets bottom="20.0" right="40.0" top="20.0"/>
                    </padding>
                </LineChart>
            </children>
        </HBox>
    </children>
